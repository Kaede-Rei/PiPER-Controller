<launch>
    <!-- 真机控制 - 启动 PiPER 控制节点 -->
    <include file="$(find piper)/launch/start_single_piper.launch" />
    <node name="delay_for_moveit" pkg="roscpp_tutorials" type="talker" launch-prefix="bash -c 'sleep 3; exec '" output="screen" />

    <include file="$(find piper_with_gripper_moveit)/launch/demo.launch" />
    <node pkg="piper_interface" type="piper_start" name="piper_start" output="screen">
        <rosparam command="load" file="$(find piper_interface)/config/config.yaml" />
    </node>
</launch>