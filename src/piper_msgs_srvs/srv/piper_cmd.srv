# 请求部分
string command      # 命令
string param1       # 参数1: 对于line/arc是起点坐标字符串
string param2       # 参数2: 对于line/arc是终点坐标字符串
string param3       # 参数3: 备用参数
float64 x           # 目标位置x坐标
float64 y           # 目标位置y坐标
float64 z           # 目标位置z坐标
float64 roll        # 目标姿态roll角
float64 pitch       # 目标姿态pitch角
float64 yaw         # 目标姿态yaw角
---
# 响应部分
bool success        # 执行是否成功
string message      # 返回消息